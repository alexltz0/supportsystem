<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — <%= branding.name %></title>
  <link href="<%= branding.logo %>" rel="icon">
  <link rel="stylesheet" href="css/app.css">
</head>
<body>
  <div class="auth-wrapper">
    <div class="auth-card fade-in">
      <div class="auth-logo">
        <img src="<%= branding.logo %>" alt="<%= branding.name %>">
        <h1><%= branding.name %></h1>
      </div>
      <p class="auth-subtitle"><%= branding.subtitle %> — Anmelden</p>

      <% if (error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>

      <form class="auth-form" method="post" action="/login">
        <div class="form-group">
          <label class="form-label" for="user_name">Benutzername</label>
          <input class="form-input" type="text" id="user_name" name="user_name" placeholder="Dein Benutzername" required autofocus>
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Passwort</label>
          <input class="form-input" type="password" id="password" name="password" placeholder="Dein Passwort" required>
        </div>
        <div class="auth-actions">
          <button class="btn btn-primary" type="submit">Anmelden</button>
        </div>
      </form>

      <div class="auth-switch">
        Noch kein Konto? <a href="/signup">Registrieren</a>
      </div>
    </div>
  </div>
</body>
</html>
