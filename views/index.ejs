<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — <%= branding.name %></title>
  <link href="<%= branding.logo %>" rel="icon">
  <link rel="stylesheet" href="css/app.css">
</head>
<body>

  <!-- Topbar -->
  <nav class="topbar">
    <div class="topbar-brand">
      <img src="<%= branding.logo %>" alt="<%= branding.name %>">
      <span class="topbar-title"><%= branding.name %></span>
    </div>
    <div class="topbar-nav">
      <a href="/" class="active">Dashboard</a>
      <a href="/form">Support Eintragen</a>
      <% if (user_data.admin == 1) { %>
      <a href="/admin">Admin</a>
      <% } %>
    </div>
    <div class="topbar-user">
      <div class="user-avatar"><%= user_data.user_name.charAt(0).toUpperCase() %></div>
      <span class="user-name"><%= user_data.user_name %></span>
      <button class="btn-logout" onclick="window.location.href='/logout'">Abmelden</button>
    </div>
  </nav>

  <!-- Content -->
  <div class="page-content">

    <!-- Stat Cards -->
    <div class="stat-grid fade-in">
      <div class="stat-card">
        <div class="stat-label">Meine Tickets</div>
        <div class="stat-value"><%= myTickets.length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Tickets Gesamt</div>
        <div class="stat-value"><%= totalTickets %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Aktive Tage</div>
        <div class="stat-value"><%= ticketsPerDay.length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Ø Tickets / Tag</div>
        <div class="stat-value"><%= ticketsPerDay.length > 0 ? (myTickets.length / ticketsPerDay.length).toFixed(1) : '0' %></div>
      </div>
    </div>

    <!-- Tickets pro Tag (Balkendiagramm) -->
    <% if (ticketsPerDay.length > 0) { %>
    <div class="glass-card fade-in fade-in-delay-1">
      <div class="section-title">
        <div class="icon">📊</div>
        Meine Aktivität
      </div>
      <% const maxDay = Math.max(...ticketsPerDay.map(d => d.count)); %>
      <% const recentDays = ticketsPerDay.slice(0, 30); %>
      <style>
        .timeline-bar { display: flex; align-items: flex-end; gap: 4px; height: 80px; padding-top: 8px; }
        .timeline-bar .bar { flex: 1; min-width: 20px; max-width: 48px; background: linear-gradient(180deg, var(--accent), var(--accent-hover, #cc0062)); border-radius: 4px 4px 0 0; position: relative; transition: var(--transition); cursor: default; }
        .timeline-bar .bar:hover { opacity: 0.8; }
        .timeline-bar .bar .bar-tooltip { position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%); background: var(--bg-secondary, #0d0629); border: 1px solid var(--glass-border); padding: 4px 8px; border-radius: 6px; font-size: 11px; color: var(--text); white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.2s; z-index: 10; }
        .timeline-bar .bar:hover .bar-tooltip { opacity: 1; }
        .timeline-labels { display: flex; gap: 4px; margin-top: 4px; }
        .timeline-labels span { flex: 1; min-width: 20px; max-width: 48px; text-align: center; font-size: 10px; color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      </style>
      <div class="timeline-bar">
        <% recentDays.slice().reverse().forEach(function(d) { %>
          <div class="bar" style="height: <%= Math.max((d.count / maxDay) * 100, 8) %>%;">
            <div class="bar-tooltip"><%= d.day ? new Date(d.day).toLocaleDateString('de-DE') : '—' %>: <%= d.count %></div>
          </div>
        <% }); %>
      </div>
      <div class="timeline-labels">
        <% recentDays.slice().reverse().forEach(function(d) { %>
          <span><%= d.day ? new Date(d.day).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit' }) : '' %></span>
        <% }); %>
      </div>
      <% if (ticketsPerDay.length > 30) { %>
        <p style="font-size: 12px; color: var(--text-muted); margin-top: 12px;">Zeigt die letzten 30 Tage mit Aktivität</p>
      <% } %>
    </div>
    <% } %>

    <!-- Tickets pro Monat -->
    <% if (ticketsPerMonth.length > 0) { %>
    <div class="glass-card fade-in fade-in-delay-2">
      <div class="section-title">
        <div class="icon">📅</div>
        Tickets pro Monat
      </div>
      <table class="data-table">
        <thead>
          <tr>
            <th>Monat</th>
            <th>Anzahl</th>
          </tr>
        </thead>
        <tbody>
          <% ticketsPerMonth.forEach(function(m) { %>
          <tr>
            <td><%= m.month %></td>
            <td><span style="font-weight: 600; color: var(--accent);"><%= m.count %></span></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- My Tickets Table -->
    <div class="glass-card fade-in fade-in-delay-3">
      <div class="section-title">
        <div class="icon">📋</div>
        Meine Tickets
      </div>

      <% if (myTickets.length > 0) { %>
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>User (Discord)</th>
            <th>Grund</th>
            <th>Ausgang</th>
            <th>Datum</th>
          </tr>
        </thead>
        <tbody>
          <% myTickets.forEach(function(ticket, i) { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= ticket.user %></td>
            <td><%= ticket.grund %></td>
            <td><%= ticket.ausgang %></td>
            <td style="white-space: nowrap; color: var(--text-muted);">
              <%= ticket.created_at ? new Date(ticket.created_at).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—' %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">📭</div>
        <p>Du hast noch keine Tickets eingetragen.</p>
      </div>
      <% } %>
    </div>

  </div>

</body>
</html>
